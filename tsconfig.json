{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    "module": "node16",
    "target": "es2025",
    "moduleResolution": "node16",
    "strict": true,
    "noImplicitAny": true,
    "declaration": false,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
